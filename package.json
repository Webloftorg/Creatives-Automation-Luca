    "@supabase/supabase-js": "^2.101.1",
    "concurrently": "^9.2.1",
    "jszip": "^3.10.1",
    "next": "16.2.2",
    "pngjs": "^7.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "semver": "^7.7.4",
    "sharp": "^0.34.5",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"

      "id": "5d54db88-d48c-42ae-b93e-b66bd9ef0ea0",
      "templateHtml": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Fitness Ad Template</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --width: {{width}}px;\n            --height: {{height}}px;\n            --bg-image: url('{{backgroundImage}}');\n            --person-image: url('{{personImage}}');\n            --primary-color: {{primaryColor}};\n            --accent-color: {{accentColor}};\n            --bg-blur: 6px;\n            --bg-brightness: 0.35;\n            --headline-size: 52px;\n            --price-size: 72px;\n            --person-scale: 1;\n            --person-position-x: 65%;\n            --person-position-y: 20%;\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: var(--width);\n            height: var(--height);\n            font-family: 'Montserrat', sans-serif;\n            overflow: hidden;\n            position: relative;\n        }\n\n        .background {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-image: var(--bg-image);\n            background-size: cover;\n            background-position: center;\n            filter: blur(var(--bg-blur)) brightness(var(--bg-brightness));\n        }\n\n        .content-wrapper {\n            position: relative;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            z-index: 2;\n        }\n\n        .location {\n            position: absolute;\n            top: 30px;\n            right: 40px;\n            color: white;\n            font-weight: 700;\n            font-size: 18px;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n        }\n\n        .main-content {\n            flex: 1;\n            display: flex;\n            align-items: flex-end;\n            padding: 60px 40px;\n            position: relative;\n        }\n\n        .text-section {\n            width: 55%;\n            z-index: 3;\n        }\n\n        .headline {\n            color: white;\n            font-size: var(--headline-size);\n            font-weight: 900;\n            line-height: 0.9;\n            text-transform: uppercase;\n            letter-spacing: -1px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            margin-bottom: 25px;\n        }\n\n        .headline span {\n            color: var(--primary-color);\n        }\n\n        .price-container {\n            background: linear-gradient(135deg, #000000cc, #111111bb);\n            padding: 20px 30px;\n            border-radius: 15px;\n            border-left: 6px solid var(--primary-color);\n            margin-bottom: 20px;\n            box-shadow: 0 8px 24px rgba(0,0,0,0.4);\n        }\n\n        .price {\n            color: var(--primary-color);\n            font-size: var(--price-size);\n            font-weight: 900;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            line-height: 1;\n        }\n\n        .original-price {\n            color: white;\n            font-size: 32px;\n            font-weight: 600;\n            text-decoration: line-through;\n            opacity: 0.7;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            margin-top: 5px;\n        }\n\n        .cta {\n            color: white;\n            font-size: 20px;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 1px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n        }\n\n        .person {\n            position: absolute;\n            right: var(--person-position-x);\n            top: var(--person-position-y);\n            transform: translateX(50%) scale(var(--person-scale));\n            width: 450px;\n            height: 600px;\n            background-image: var(--person-image);\n            background-size: contain;\n            background-position: center bottom;\n            background-repeat: no-repeat;\n            z-index: 2;\n            filter: drop-shadow(0 10px 30px rgba(0,0,0,0.5));\n        }\n\n        .accent-shape {\n            position: absolute;\n            top: 0;\n            right: 0;\n            width: 300px;\n            height: 100%;\n            background: linear-gradient(180deg, var(--primary-color)22, transparent 70%);\n            clip-path: polygon(40% 0%, 100% 0%, 100% 100%, 0% 100%);\n            z-index: 1;\n        }\n\n        .bottom-accent {\n            position: absolute;\n            bottom: 0;\n            left: 0;\n            width: 100%;\n            height: 8px;\n            background: linear-gradient(90deg, var(--primary-color), var(--accent-color));\n        }\n    </style>\n</head>\n<body>\n    <div class=\"background\"></div>\n    \n    <div class=\"content-wrapper\">\n        <div class=\"location\">{{location}}</div>\n        \n        <div class=\"accent-shape\"></div>\n        \n        <div class=\"person\"></div>\n        \n        <div class=\"main-content\">\n            <div class=\"text-section\">\n                <h1 class=\"headline\">\n                    Jetzt <span>starten</span><br>\n                    bei power fit\n                </h1>\n                \n                <div class=\"price-container\">\n                    <div class=\"price\">39,90€</div>\n                    <div class=\"original-price\">79,90€</div>\n                </div>\n                \n                <div class=\"cta\">Limitiertes Angebot!</div>\n            </div>\n        </div>\n        \n        <div class=\"bottom-accent\"></div>\n    </div>\n</body>\n</html>",

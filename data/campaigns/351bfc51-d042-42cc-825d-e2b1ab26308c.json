      "id": "9c6d9b3f-4d2b-43c8-be05-789f77fd761c",
      "templateHtml": "<!DOCTYPE html>\n<html lang=\"de\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Power Fit Angebot</title>\n    <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n    <style>\n        :root {\n            --bg-blur: 6px;\n            --bg-brightness: 0.4;\n            --headline-size: 48px;\n            --price-size: 72px;\n            --original-price-size: 36px;\n            --person-scale: 1.0;\n            --person-position-x: 50%;\n            --person-position-y: 45%;\n            --primary-color: {{primaryColor}};\n            --accent-color: {{accentColor}};\n        }\n\n        * {\n            margin: 0;\n            padding: 0;\n            box-sizing: border-box;\n        }\n\n        body {\n            width: {{width}}px;\n            height: {{height}}px;\n            font-family: 'Montserrat', Arial, sans-serif;\n            position: relative;\n            overflow: hidden;\n            background: #000;\n        }\n\n        .background {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background-image: url('{{backgroundImage}}');\n            background-size: cover;\n            background-position: center;\n            filter: blur(var(--bg-blur)) brightness(var(--bg-brightness));\n            z-index: 1;\n        }\n\n        .overlay {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            background: linear-gradient(135deg, rgba(0,0,0,0.2) 0%, rgba(255,69,0,0.1) 100%);\n            z-index: 2;\n        }\n\n        .location {\n            position: absolute;\n            top: 40px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: white;\n            font-weight: 700;\n            font-size: 24px;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            z-index: 5;\n        }\n\n        .person {\n            position: absolute;\n            left: var(--person-position-x);\n            top: var(--person-position-y);\n            transform: translate(-50%, -50%) scale(var(--person-scale));\n            z-index: 3;\n            max-width: 600px;\n            max-height: 800px;\n        }\n\n        .person img {\n            width: 100%;\n            height: auto;\n            display: block;\n        }\n\n        .content {\n            position: absolute;\n            top: 0;\n            left: 0;\n            width: 100%;\n            height: 100%;\n            display: flex;\n            flex-direction: column;\n            justify-content: center;\n            align-items: center;\n            z-index: 4;\n            padding: 60px 40px;\n            text-align: center;\n        }\n\n        .headline {\n            color: white;\n            font-weight: 900;\n            font-size: var(--headline-size);\n            text-transform: uppercase;\n            letter-spacing: 3px;\n            line-height: 1.2;\n            margin-bottom: 40px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            max-width: 800px;\n        }\n\n        .price-container {\n            background: rgba(0,0,0,0.8);\n            padding: 30px 50px;\n            border-radius: 15px;\n            margin-bottom: 30px;\n            backdrop-filter: blur(10px);\n            border: 2px solid var(--accent-color);\n        }\n\n        .original-price {\n            color: #ccc;\n            font-size: var(--original-price-size);\n            font-weight: 700;\n            text-decoration: line-through;\n            opacity: 0.7;\n            margin-bottom: 10px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n        }\n\n        .current-price {\n            color: var(--primary-color);\n            font-size: var(--price-size);\n            font-weight: 900;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n        }\n\n        .cta {\n            color: white;\n            font-size: 28px;\n            font-weight: 700;\n            text-transform: uppercase;\n            letter-spacing: 2px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            background: linear-gradient(45deg, var(--primary-color), var(--accent-color));\n            padding: 20px 40px;\n            border-radius: 50px;\n            border: none;\n            cursor: pointer;\n            transition: all 0.3s ease;\n        }\n\n        .studio-name {\n            position: absolute;\n            bottom: 40px;\n            left: 50%;\n            transform: translateX(-50%);\n            color: white;\n            font-size: 32px;\n            font-weight: 900;\n            text-transform: uppercase;\n            letter-spacing: 3px;\n            text-shadow: 2px 2px 8px rgba(0,0,0,0.8);\n            z-index: 5;\n        }\n    </style>\n</head>\n<body>\n    <div class=\"background\"></div>\n    <div class=\"overlay\"></div>\n    \n    <div class=\"location\">{{location}}</div>\n    \n    <div class=\"person\">\n        <img src=\"{{personImage}}\" alt=\"Fitness Person\">\n    </div>\n    \n    <div class=\"content\">\n        <h1 class=\"headline\">Jetzt Durchstarten<br>& Fit Werden!</h1>\n        \n        <div class=\"price-container\">\n            <div class=\"original-price\">69,90€</div>\n            <div class=\"current-price\">39,90€</div>\n        </div>\n        \n        <div class=\"cta\">Jetzt Anmelden</div>\n    </div>\n    \n    <div class=\"studio-name\">power fit</div>\n</body>\n</html>",

      "templateHtml": "<!DOCTYPE html>\n<html>\n<head>\n  <meta charset=\"UTF-8\">\n  <link href=\"https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700;900&display=swap\" rel=\"stylesheet\">\n  <style>\n    :root {\n      --primary-color: {{primaryColor}};\n      --accent-color: {{accentColor}};\n      --bg-blur: 8px;\n      --bg-brightness: 0.25;\n      --headline-size: 68px;\n      --price-size: 88px;\n      --person-scale: 0.95;\n      --person-position-y: 0%;\n      --location-size: 32px;\n      --strikethrough-size: 32px;\n      --neon-glow: 0 0 40px var(--accent-color);\n    }\n    * { margin: 0; padding: 0; box-sizing: border-box; }\n    .creative-container {\n      width: {{width}}px; height: {{height}}px;\n      position: relative; overflow: hidden;\n      font-family: 'Montserrat', sans-serif; background: #0a0a0a;\n    }\n    .background {\n      position: absolute; inset: 0;\n      background-image: url('{{backgroundImage}}');\n      background-size: cover; background-position: center;\n      filter: blur(var(--bg-blur)) brightness(var(--bg-brightness));\n      transform: scale(1.2);\n    }\n    .overlay {\n      position: absolute; inset: 0;\n      background: radial-gradient(circle at 20% 80%, rgba(255,55,0,0.15) 0%, rgba(0,0,0,0.3) 40%, rgba(0,0,0,0.8) 100%);\n      z-index: 1;\n    }\n    .person {\n      position: absolute; z-index: 2;\n      bottom: var(--person-position-y); right: -10%;\n      transform: scale(var(--person-scale));\n      height: 100%; width: auto; object-fit: contain;\n      filter: drop-shadow(-8px 0 25px rgba(255,55,0,0.4));\n    }\n    .content {\n      position: absolute; z-index: 3; inset: 0;\n      display: flex; flex-direction: column;\n      justify-content: flex-start; padding: 50px;\n    }\n    .location { \n      font-size: var(--location-size); font-weight: 700; color: white; \n      text-align: left; text-shadow: 2px 2px 8px rgba(0,0,0,0.8); \n      text-transform: uppercase; letter-spacing: 3px; margin-bottom: 30px;\n      filter: drop-shadow(var(--neon-glow));\n    }\n    .headline { \n      font-size: var(--headline-size); font-weight: 900; color: white; \n      text-transform: uppercase; text-shadow: 2px 2px 8px rgba(0,0,0,0.8); \n      line-height: 0.95; margin-bottom: 40px; text-align: left; max-width: 65%;\n      filter: drop-shadow(0 0 20px rgba(255,255,255,0.3));\n    }\n    .price-block { \n      background: linear-gradient(135deg, rgba(0,0,0,0.9) 0%, rgba(255,55,0,0.1) 100%); \n      display: inline-block; padding: 20px 50px; border-radius: 20px;\n      border: 3px solid var(--accent-color);\n      box-shadow: var(--neon-glow), inset 0 0 30px rgba(255,107,0,0.1);\n      align-self: flex-start;\n    }\n    .price { \n      font-size: var(--price-size); font-weight: 900; color: var(--accent-color); \n      text-shadow: var(--neon-glow); line-height: 1.1;\n      filter: drop-shadow(0 0 15px var(--accent-color));\n    }\n    .original-price { \n      font-size: var(--strikethrough-size); font-weight: 700; \n      color: rgba(255,255,255,0.7); text-decoration: line-through; \n      margin-top: 8px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);\n    }\n    .geometric-accent {\n      position: absolute; top: 30%; left: 5%;\n      width: 200px; height: 200px; z-index: 1;\n      border: 4px solid var(--accent-color);\n      border-radius: 50%; opacity: 0.3;\n      filter: blur(2px) drop-shadow(var(--neon-glow));\n      animation: pulse 3s ease-in-out infinite;\n    }\n    @keyframes pulse {\n      0%, 100% { transform: scale(1); opacity: 0.3; }\n      50% { transform: scale(1.1); opacity: 0.5; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"creative-container\">\n    <div class=\"background\"></div>\n    <div class=\"overlay\"></div>\n    <div class=\"geometric-accent\"></div>\n    <img class=\"person\" src=\"{{personImage}}\" alt=\"\">\n    <div class=\"content\">\n      <div class=\"location\">{{location}}</div>\n      <h1 class=\"headline\">{{headline}}</h1>\n      <div class=\"price-block\">\n        <div class=\"price\">{{price}}</div>\n        <div class=\"original-price\">Statt {{originalPrice}}</div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",

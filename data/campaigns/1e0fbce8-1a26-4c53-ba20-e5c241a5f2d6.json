ttom: 30px;\n      filter: drop-shadow(var(--neon-glow));\n    }\n    .headline { \n      font-size: var(--headline-size); font-weight: 900; color: white; \n      text-transform: uppercase; text-shadow: 2px 2px 8px rgba(0,0,0,0.8); \n      line-height: 0.95; margin-bottom: 40px; text-align: left; max-width: 65%;\n      filter: drop-shadow(0 0 20px rgba(255,255,255,0.3));\n    }\n    .price-block { \n      background: linear-gradient(135deg, rgba(0,0,0,0.9) 0%, rgba(255,55,0,0.1) 100%); \n      display: inline-block; padding: 20px 50px; border-radius: 20px;\n      border: 3px solid var(--accent-color);\n      box-shadow: var(--neon-glow), inset 0 0 30px rgba(255,107,0,0.1);\n      align-self: flex-start;\n    }\n    .price { \n      font-size: var(--price-size); font-weight: 900; color: var(--accent-color); \n      text-shadow: var(--neon-glow); line-height: 1.1;\n      filter: drop-shadow(0 0 15px var(--accent-color));\n    }\n    .original-price { \n      font-size: var(--strikethrough-size); font-weight: 700; \n      color: rgba(255,255,255,0.7); text-decoration: line-through; \n      margin-top: 8px; text-shadow: 2px 2px 4px rgba(0,0,0,0.8);\n    }\n    .geometric-accent {\n      position: absolute; top: 30%; left: 5%;\n      width: 200px; height: 200px; z-index: 1;\n      border: 4px solid var(--accent-color);\n      border-radius: 50%; opacity: 0.3;\n      filter: blur(2px) drop-shadow(var(--neon-glow));\n      animation: pulse 3s ease-in-out infinite;\n    }\n    @keyframes pulse {\n      0%, 100% { transform: scale(1); opacity: 0.3; }\n      50% { transform: scale(1.1); opacity: 0.5; }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"creative-container\">\n    <div class=\"background\"></div>\n    <div class=\"overlay\"></div>\n    <div class=\"geometric-accent\"></div>\n    <img class=\"person\" src=\"{{personImage}}\" alt=\"\">\n    <div class=\"content\">\n      <div class=\"location\">{{location}}</div>\n      <h1 class=\"headline\">{{headline}}</h1>\n      <div class=\"price-block\">\n        <div class=\"price\">{{price}}</div>\n        <div class=\"original-price\">Statt {{originalPrice}}</div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",

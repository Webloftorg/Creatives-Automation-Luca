-transform: uppercase; letter-spacing: 2px;\n      background: linear-gradient(45deg, var(--primary-color), var(--accent-color));\n      -webkit-background-clip: text;\n      -webkit-text-fill-color: transparent;\n      background-clip: text;\n    }\n    .left-content {\n      max-width: 55%;\n    }\n    .headline { \n      font-size: var(--headline-size); font-weight: 900; color: white; \n      text-transform: uppercase; text-shadow: var(--neon-glow); \n      line-height: 1.05; margin-bottom: 24px;\n      text-align: left;\n    }\n    .price-block { \n      background: linear-gradient(135deg, rgba(0,0,0,0.85), rgba(20,20,20,0.9));\n      display: inline-block; padding: 20px 40px; \n      border-radius: 12px;\n      border: 2px solid var(--accent-color);\n      box-shadow: 0 0 30px rgba(255,107,0,0.3), inset 0 0 20px rgba(0,0,0,0.5);\n    }\n    .price { \n      font-size: var(--price-size); font-weight: 900; color: var(--accent-color); \n      text-shadow: var(--neon-glow); line-height: 1.1;\n      filter: drop-shadow(0 0 10px var(--accent-color));\n    }\n    .original-price { \n      font-size: var(--strikethrough-size); font-weight: 700; \n      color: rgba(255,255,255,0.6); text-decoration: line-through; \n      margin-top: 4px;\n    }\n  </style>\n</head>\n<body>\n  <div class=\"creative-container\">\n    <div class=\"background\"></div>\n    <div class=\"overlay\"></div>\n    <img class=\"person\" src=\"{{personImage}}\" alt=\"\">\n    <div class=\"content\">\n      <div class=\"location\">{{location}}</div>\n      <div class=\"left-content\">\n        <h1 class=\"headline\">{{headline}}</h1>\n        <div class=\"price-block\">\n          <div class=\"price\">{{price}}</div>\n          <div class=\"original-price\">Statt {{originalPrice}}</div>\n        </div>\n      </div>\n    </div>\n  </div>\n</body>\n</html>",
